{"id":1, "title": "AutoFill","body":"<div style=\"caret-color: rgba(0, 0, 0, 0); color: rgb(255, 255, 255); background-color: rgb(0, 26, 51);\">👍 Replicate the Double Click for Autofill in Excel</div><br style=\"caret-color: rgba(0, 0, 0, 0); color: rgb(255, 255, 255); background-color: rgb(0, 26, 51);\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"648\" style=\"caret-color: rgba(0, 0, 0, 0); color: rgb(255, 255, 255); background-color: rgb(0, 26, 51); border-collapse: collapse; width: 486pt;\"><colgroup><col width=\"72\" span=\"9\" style=\"width: 54pt;\"></colgroup><tbody><tr height=\"20\" style=\"height: 15pt;\"><td colspan=\"9\" rowspan=\"32\" height=\"640\" class=\"xl63\" width=\"648\" style=\"height: 480pt; width: 486pt;\">Sub SatisfyingAutoFill()<br>&nbsp;&nbsp;&nbsp;&nbsp;Dim lastRow As Long<br>&nbsp;&nbsp;&nbsp;&nbsp;Dim sourceCell As Range<br>&nbsp;&nbsp;&nbsp;&nbsp;Dim startRow As Long, endRow As Long<br>&nbsp;&nbsp;&nbsp;&nbsp;Dim i As Integer<br>&nbsp;&nbsp;&nbsp;&nbsp;Dim chunkSize As Long<br>&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;Set sourceCell = ActiveCell<br>&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;' Logic Change: Look DOWN from the current row in the left column<br>&nbsp;&nbsp;&nbsp;&nbsp;' This stops at the first blank cell it encounters.<br>&nbsp;&nbsp;&nbsp;&nbsp;lastRow = Cells(sourceCell.Row, sourceCell.Column - 1).End(xlDown).Row<br>&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;' Safety check: If the adjacent column is empty or row is huge, don't run<br>&nbsp;&nbsp;&nbsp;&nbsp;If lastRow &gt; Rows.Count Or lastRow &lt;= sourceCell.Row Then<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;MsgBox \"No contiguous data found in the left column.\", vbExclamation<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Exit Sub<br>&nbsp;&nbsp;&nbsp;&nbsp;End If<br>&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;' Reset the visual animation logic<br>&nbsp;&nbsp;&nbsp;&nbsp;chunkSize = (lastRow - sourceCell.Row) / 10<br>&nbsp;&nbsp;&nbsp;&nbsp;If chunkSize &lt; 1 Then chunkSize = 1<br>&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;startRow = sourceCell.Row<br>&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;For i = 1 To 10<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;endRow = startRow + chunkSize<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;If endRow &gt; lastRow Or i = 10 Then endRow = lastRow<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Range(sourceCell, Cells(endRow, sourceCell.Column)).FillDown<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;DoEvents<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Application.Wait (Now + TimeValue(\"0:00:01\") / 10) ' Slightly faster pause<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;startRow = endRow<br>&nbsp;&nbsp;&nbsp;&nbsp;Next i<br>End Sub</td></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr><tr height=\"20\" style=\"height: 15pt;\"></tr></tbody></table>"}
